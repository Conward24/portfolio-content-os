# Portfolio Content OS — Environment Variables
# Copy this file to .env.local and fill in values

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Upstash Redis (NEW instance — separate from MyLÚA app)
KV_REST_API_URL=your_upstash_redis_url_here
KV_REST_API_TOKEN=your_upstash_redis_token_here

# Vercel Blob (NEW instance — separate from MyLÚA app)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
